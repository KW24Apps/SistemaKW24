# ── Conexão com o PostgreSQL (banco do relatório Contabilidade) ──────────────
# Copie este arquivo para ".env" e preencha com os dados reais da VPS.
# O .env NÃO é versionado (está no .gitignore).
# Mesmo host/porta/usuário/senha do relatorio-parceiros-tax — só muda DB_NAME.
DB_HOST=IP_DA_SUA_VPS
DB_PORT=5432
DB_NAME=bx_sync_contabilidade
DB_USER=postgres
DB_PASSWORD=coloque_a_senha_aqui

# ── App Dash ─────────────────────────────────────────────────────────────────
# Porta 8050 já é usada pelo relatorio-parceiros-tax — este app usa 8051.
APP_HOST=127.0.0.1
APP_PORT=8051
APP_DEBUG=true
